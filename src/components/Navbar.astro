---
import { Icon } from "astro-icon/components";

const navItems = [
    { label: "Home", href: "/home" },
    { label: "Blog", href: "/blog" },
    { label: "Tags", href: "/tags" },
    { label: "Notes", href: "/notes" },
    { label: "Archives", href: "/archives" },
    { label: "About", href: "/about" }
];

const currentPath = Astro.url.pathname;
---
<header class="navbar">
    <div class="navbar__container">
        <div class="navbar__branding">
            <div class="navbar__logo">
                <img src="src/assets/logo.svg" alt="logo" class="navbar__logo-img" />
            </div>
            <div class="navbar__text">
                <a href="/" class="navbar__name">
                Santo-Ryu
                </a>

                <a href="/" class="navbar__tagline">
                    Investigate. Analyze. Understand.
                </a>
            </div>
        </div>

        <nav class="navbar__nav">
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class:list={[
                            "navbar__link",
                            item.href === currentPath && "is-active"
                        ]}
                    >
                        {item.label}
                    </a>
                ))
            }

            <button
                id="theme-toggle"
                class="navbar__theme-toggle"
                aria-label="Toggle theme"
            >
                <Icon
                    name="lucide:sun"
                    class="navbar__theme-icon navbar__theme-icon--sun"
                />

                <Icon
                    name="lucide:moon"
                    class="navbar__theme-icon navbar__theme-icon--moon"
                />
            </button>
        </nav>
    </div>
</header>

<script is:inline>
    const root = document.documentElement;
    const btn = document.getElementById("theme-toggle");

    const saved = localStorage.getItem("theme");

    if (saved) {
        root.classList.toggle("light", saved === "light");
    } else {
        root.classList.toggle(
            "light",
            !window.matchMedia("(prefers-color-scheme: dark)").matches
        );
    }

    btn?.addEventListener("click", () => {
        root.classList.toggle("light");

        localStorage.setItem(
            "theme",
            root.classList.contains("light") ? "light" : "dark"
        );
    });
</script>
